            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def response = prev.getResponseDataAsString()

def matcher = response =~ /&lt;input type=&quot;hidden&quot; name=&quot;userSession&quot; value=&quot;([^&quot;]+)&quot;/

if (matcher.find()) {

    def userSession = matcher.group(1)

    vars.put(&quot;USER_SESSION&quot;, userSession)

    log.info(&quot;Extracted userSession: &quot; + userSession)

} else {

    log.warn(&quot;userSession not found&quot;)
}</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
