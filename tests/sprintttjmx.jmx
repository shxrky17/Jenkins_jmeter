            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">def response = prev.getResponseDataAsString()

def matcher = response =~ /name=&quot;advanceDiscount&quot; value=&quot;([^&quot;]+)&quot;/

if (matcher.find()) {

    def discount = matcher.group(1)

    vars.put(&quot;ADVANCE_DISCOUNT&quot;, discount)

    log.info(&quot;Advance Discount: &quot; + discount)

} else {

    log.warn(&quot;advanceDiscount not found&quot;)
}</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
