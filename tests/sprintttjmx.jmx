              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def response = prev.getResponseDataAsString()

def matcher = response =~ /&lt;input type=&quot;hidden&quot; name=&quot;userSession&quot; value=&quot;([^&quot;]+)&quot;/

if (matcher.find()) {

    def userSession = matcher.group(1)

    vars.put(&quot;userSession&quot;, userSession)

} else {

    log.warn(&quot;userSession not found&quot;)

    prev.setResponseMessage(&quot;userSession not found&quot;)
}</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
